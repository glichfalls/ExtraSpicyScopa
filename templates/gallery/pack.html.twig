{% extends 'base.html.twig' %}

{% block title %}{{ pack.user.firstName }}'s Stickers - Extra Spicy Stickers{% endblock %}

{% block styles %}
    .pack-page {
        max-width: 900px;
        margin: 0 auto;
        padding: 2rem;
    }

    .pack-header {
        margin-bottom: 2rem;
    }

    .pack-header h1 {
        font-size: 1.8rem;
        color: #e0e0e0;
        margin-bottom: 0.3rem;
    }

    .pack-meta {
        font-size: 0.9rem;
        color: #888;
    }

    .pack-meta a {
        color: #ff6b35;
    }

    .breadcrumb {
        font-size: 0.85rem;
        color: #555;
        margin-bottom: 1rem;
    }

    .breadcrumb a { color: #888; }
    .breadcrumb a:hover { color: #e0e0e0; }

    .stickers {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: 1rem;
    }

    .sticker-card {
        background: #1a1a1a;
        border-radius: 12px;
        border: 1px solid #2a2a2a;
        padding: 1rem;
        text-align: center;
    }

    .sticker-emoji {
        font-size: 2rem;
        margin-bottom: 0.5rem;
    }

    .sticker-prompt {
        font-size: 0.8rem;
        color: #888;
        line-height: 1.4;
        overflow: hidden;
        text-overflow: ellipsis;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
    }

    .sticker-date {
        font-size: 0.75rem;
        color: #555;
        margin-top: 0.5rem;
    }

    .empty {
        color: #555;
        font-size: 1rem;
        padding: 3rem;
        text-align: center;
    }
{% endblock %}

{% block body %}
    <div class="pack-page">
        <div class="breadcrumb">
            <a href="{{ path('gallery') }}">Gallery</a> / {{ pack.user.firstName }}'s Stickers
        </div>

        <div class="pack-header">
            <h1>{{ pack.user.firstName }}'s Stickers</h1>
            <p class="pack-meta">
                {{ stickers|length }} sticker{{ stickers|length != 1 ? 's' : '' }}
                &middot;
                <a href="https://t.me/addstickers/{{ pack.name }}">Add to Telegram</a>
            </p>
        </div>

        {% if stickers is empty %}
            <p class="empty">No stickers in this pack yet.</p>
        {% else %}
            <div class="stickers">
                {% for sticker in stickers %}
                    <div class="sticker-card">
                        <div class="sticker-emoji">{{ sticker.emoji }}</div>
                        <div class="sticker-prompt">{{ sticker.prompt }}</div>
                        <div class="sticker-date">{{ sticker.createdAt|date('M j, Y') }}</div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
{% endblock %}
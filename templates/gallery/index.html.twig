{% extends 'base.html.twig' %}

{% block title %}Gallery - Extra Spicy Stickers{% endblock %}

{% block styles %}
    .gallery-page {
        max-width: 900px;
        margin: 0 auto;
        padding: 2rem;
    }

    .gallery-page h1 {
        font-size: 1.8rem;
        margin-bottom: 1.5rem;
        color: #e0e0e0;
    }

    .packs {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
        gap: 1rem;
    }

    .pack-card {
        display: block;
        padding: 1.5rem;
        background: #1a1a1a;
        border-radius: 12px;
        border: 1px solid #2a2a2a;
        text-decoration: none;
        transition: border-color 0.2s;
    }

    .pack-card:hover {
        border-color: #ff6b35;
    }

    .pack-name {
        font-size: 1.1rem;
        font-weight: 600;
        color: #fff;
        margin-bottom: 0.3rem;
    }

    .pack-user {
        font-size: 0.85rem;
        color: #888;
    }

    .empty {
        color: #555;
        font-size: 1rem;
        padding: 3rem;
        text-align: center;
    }

    @media (max-width: 600px) {
        .gallery-page {
            padding: 1.25rem 1rem;
        }

        .gallery-page h1 {
            font-size: 1.4rem;
            margin-bottom: 1rem;
        }

        .packs {
            grid-template-columns: 1fr;
        }

        .pack-card {
            padding: 1.25rem;
        }
    }
{% endblock %}

{% block body %}
    <div class="gallery-page">
        <h1>Sticker Packs</h1>

        {% if packs is empty %}
            <p class="empty">No sticker packs yet. Be the first to create one!</p>
        {% else %}
            <div class="packs">
                {% for pack in packs %}
                    <a href="{{ path('gallery_pack', {id: pack.id}) }}" class="pack-card">
                        <div class="pack-name">{{ pack.user.firstName }}'s Stickers</div>
                        <div class="pack-user">
                            {% if pack.user.username %}@{{ pack.user.username }}{% endif %}
                        </div>
                    </a>
                {% endfor %}
            </div>
        {% endif %}
    </div>
{% endblock %}

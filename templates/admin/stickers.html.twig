{% extends 'admin/layout.html.twig' %}

{% block title %}Stickers - Admin{% endblock %}

{% block admin_styles %}
    .sticker-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
        gap: 1rem;
    }

    .sticker-card {
        background: #1a1a1a;
        border: 1px solid #2a2a2a;
        border-radius: 12px;
        padding: 0.75rem;
        text-align: center;
    }

    .sticker-card img {
        width: 100%;
        max-width: 120px;
        height: auto;
        margin-bottom: 0.5rem;
    }

    .sticker-card .emoji {
        font-size: 1.5rem;
        margin-bottom: 0.3rem;
    }

    .sticker-card .prompt {
        font-size: 0.75rem;
        color: #888;
        line-height: 1.3;
        overflow: hidden;
        text-overflow: ellipsis;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
    }

    .sticker-card .meta {
        font-size: 0.7rem;
        color: #555;
        margin-top: 0.4rem;
    }

    @media (max-width: 600px) {
        .sticker-grid {
            grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
            gap: 0.75rem;
        }

        .sticker-card {
            padding: 0.5rem;
        }

        .sticker-card img {
            max-width: 100%;
        }
    }
{% endblock %}

{% block admin_body %}
    <h1>Recent Stickers</h1>

    {% if stickers is empty %}
        <p style="color:#555;">No stickers yet.</p>
    {% else %}
        <div class="sticker-grid">
            {% for sticker in stickers %}
                <div class="sticker-card">
                    {% if sticker.imagePath %}
                        <img src="{{ asset(sticker.imagePath) }}" alt="{{ sticker.prompt }}">
                    {% else %}
                        <div class="emoji">{{ sticker.emoji }}</div>
                    {% endif %}
                    <div class="prompt">{{ sticker.prompt }}</div>
                    <div class="meta">
                        {{ sticker.pack.user.firstName }} &middot; {{ sticker.createdAt|date('M j') }}
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}

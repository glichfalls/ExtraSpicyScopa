{% extends 'base.html.twig' %}

{% block title %}Admin Login - Extra Spicy Stickers{% endblock %}

{% block styles %}
    .login-page {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: calc(100vh - 56px);
        padding: 2rem;
    }

    .login-card {
        width: 100%;
        max-width: 360px;
        background: #1a1a1a;
        border: 1px solid #2a2a2a;
        border-radius: 16px;
        padding: 2.5rem;
    }

    .login-card h1 {
        font-size: 1.3rem;
        font-weight: 600;
        color: #fff;
        margin-bottom: 0.5rem;
    }

    .login-card p {
        font-size: 0.85rem;
        color: #666;
        margin-bottom: 1.5rem;
    }

    .login-error {
        background: rgba(255, 51, 102, 0.1);
        border: 1px solid rgba(255, 51, 102, 0.2);
        color: #ff3366;
        font-size: 0.85rem;
        padding: 0.6rem 1rem;
        border-radius: 8px;
        margin-bottom: 1rem;
    }

    .form-group {
        margin-bottom: 0.75rem;
    }

    .form-input {
        width: 100%;
        padding: 0.7rem 1rem;
        background: #0f0f0f;
        border: 1px solid #333;
        border-radius: 10px;
        color: #e0e0e0;
        font-size: 0.9rem;
        outline: none;
        transition: border-color 0.15s;
    }

    .form-input:focus {
        border-color: #ff6b35;
    }

    .form-submit {
        width: 100%;
        margin-top: 0.75rem;
        padding: 0.7rem;
        background: linear-gradient(135deg, #ff6b35, #ff3366);
        color: #fff;
        border: none;
        border-radius: 10px;
        font-size: 0.9rem;
        font-weight: 600;
        cursor: pointer;
        transition: opacity 0.15s;
    }

    .form-submit:hover {
        opacity: 0.9;
    }
{% endblock %}

{% block body %}
    <div class="login-page">
        <form class="login-card" method="post">
            <h1>Admin Panel</h1>
            <p>Sign in with your Telegram username.</p>

            {% if error %}
                <div class="login-error">{{ error }}</div>
            {% endif %}

            <div class="form-group">
                <input type="text" name="username" class="form-input" placeholder="Telegram username" autofocus required>
            </div>
            <div class="form-group">
                <input type="password" name="password" class="form-input" placeholder="Password" required>
            </div>
            <button type="submit" class="form-submit">Log in</button>
        </form>
    </div>
{% endblock %}

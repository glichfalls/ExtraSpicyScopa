{% extends 'base.html.twig' %}

{% block styles %}
    .admin {
        display: flex;
        min-height: calc(100vh - 56px);
    }

    .admin-sidebar {
        width: 220px;
        background: #141414;
        border-right: 1px solid rgba(255, 255, 255, 0.06);
        padding: 1.5rem 0;
        flex-shrink: 0;
    }

    .admin-sidebar-title {
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #555;
        padding: 0 1.25rem;
        margin-bottom: 0.75rem;
    }

    .admin-sidebar a {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.5rem 1.25rem;
        font-size: 0.875rem;
        color: #888;
        transition: color 0.15s, background 0.15s;
    }

    .admin-sidebar a:hover,
    .admin-sidebar a.active {
        color: #e0e0e0;
        background: rgba(255, 255, 255, 0.04);
    }

    .admin-sidebar a.active {
        border-right: 2px solid #ff6b35;
    }

    .admin-sidebar .sidebar-icon {
        font-size: 1rem;
        width: 1.2rem;
        text-align: center;
    }

    .admin-sidebar .logout-link {
        margin-top: 1.5rem;
        padding-top: 1rem;
        border-top: 1px solid rgba(255, 255, 255, 0.06);
    }

    .admin-content {
        flex: 1;
        padding: 2rem;
        max-width: 1000px;
    }

    .admin-content h1 {
        font-size: 1.5rem;
        font-weight: 600;
        color: #fff;
        margin-bottom: 1.5rem;
    }

    .stat-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: 1rem;
        margin-bottom: 2rem;
    }

    .stat-card {
        background: #1a1a1a;
        border: 1px solid #2a2a2a;
        border-radius: 12px;
        padding: 1.25rem;
    }

    .stat-value {
        font-size: 2rem;
        font-weight: 700;
        color: #fff;
        line-height: 1;
    }

    .stat-label {
        font-size: 0.8rem;
        color: #666;
        margin-top: 0.35rem;
    }

    .data-table {
        width: 100%;
        border-collapse: collapse;
    }

    .data-table th {
        text-align: left;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #555;
        padding: 0.6rem 1rem;
        border-bottom: 1px solid #2a2a2a;
    }

    .data-table td {
        padding: 0.75rem 1rem;
        font-size: 0.875rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.04);
        color: #ccc;
    }

    .data-table tr:hover td {
        background: rgba(255, 255, 255, 0.02);
    }

    .badge {
        display: inline-block;
        padding: 0.15rem 0.5rem;
        border-radius: 6px;
        font-size: 0.75rem;
        font-weight: 500;
    }

    .badge-orange {
        background: rgba(255, 107, 53, 0.15);
        color: #ff6b35;
    }

    .btn {
        display: inline-block;
        padding: 0.4rem 0.9rem;
        font-size: 0.8rem;
        font-weight: 500;
        border-radius: 8px;
        border: none;
        cursor: pointer;
        transition: opacity 0.15s;
        text-decoration: none;
    }

    .btn:hover { opacity: 0.85; }

    .btn-primary {
        background: linear-gradient(135deg, #ff6b35, #ff3366);
        color: #fff;
    }

    .btn-ghost {
        background: rgba(255, 255, 255, 0.06);
        color: #ccc;
    }

    .form-group {
        margin-bottom: 1rem;
    }

    .form-label {
        display: block;
        font-size: 0.8rem;
        font-weight: 500;
        color: #888;
        margin-bottom: 0.35rem;
    }

    .form-input {
        width: 100%;
        max-width: 300px;
        padding: 0.6rem 0.9rem;
        background: #0f0f0f;
        border: 1px solid #333;
        border-radius: 8px;
        color: #e0e0e0;
        font-size: 0.875rem;
        outline: none;
        transition: border-color 0.15s;
    }

    .form-input:focus { border-color: #ff6b35; }

    .alert {
        padding: 0.6rem 1rem;
        border-radius: 8px;
        font-size: 0.85rem;
        margin-bottom: 1rem;
    }

    .alert-success {
        background: rgba(52, 211, 153, 0.1);
        border: 1px solid rgba(52, 211, 153, 0.2);
        color: #34d399;
    }

    {% block admin_styles %}{% endblock %}
{% endblock %}

{% block body %}
    <div class="admin">
        <aside class="admin-sidebar">
            <div class="admin-sidebar-title">Admin</div>
            <a href="{{ path('admin_dashboard') }}" class="{{ app.request.get('_route') == 'admin_dashboard' ? 'active' : '' }}">
                <span class="sidebar-icon">📊</span> Dashboard
            </a>
            <a href="{{ path('admin_users') }}" class="{{ app.request.get('_route') starts with 'admin_user' ? 'active' : '' }}">
                <span class="sidebar-icon">👤</span> Users
            </a>
            <a href="{{ path('admin_stickers') }}" class="{{ app.request.get('_route') == 'admin_stickers' ? 'active' : '' }}">
                <span class="sidebar-icon">🎨</span> Stickers
            </a>
            <a href="{{ path('admin_password') }}" class="logout-link {{ app.request.get('_route') == 'admin_password' ? 'active' : '' }}">
                <span class="sidebar-icon">🔑</span> Password
            </a>
            <a href="{{ path('admin_logout') }}">
                <span class="sidebar-icon">🚪</span> Log out
            </a>
        </aside>
        <main class="admin-content">
            {% block admin_body %}{% endblock %}
        </main>
    </div>
{% endblock %}

{% extends 'admin/layout.html.twig' %}

{% block title %}Change Password - Admin{% endblock %}

{% block admin_body %}
    <h1>Change Password</h1>

    {% if saved %}
        <div class="alert alert-success">Password updated.</div>
    {% endif %}

    {% if error %}
        <div class="alert" style="background:rgba(255,51,102,0.1);border:1px solid rgba(255,51,102,0.2);color:#ff3366;">{{ error }}</div>
    {% endif %}

    <form method="post">
        <div class="form-group">
            <label class="form-label">New Password</label>
            <input type="password" name="new_password" class="form-input" required minlength="8" placeholder="Min. 8 characters">
        </div>
        <div class="form-group">
            <label class="form-label">Confirm Password</label>
            <input type="password" name="confirm_password" class="form-input" required minlength="8">
        </div>
        <div style="display:flex;gap:0.5rem;margin-top:1.5rem;">
            <button type="submit" class="btn btn-primary">Update Password</button>
            <a href="{{ path('admin_dashboard') }}" class="btn btn-ghost">Cancel</a>
        </div>
    </form>
{% endblock %}

# Production Environment Configuration
# Copy this to .env on the server and fill in the values

APP_ENV=prod
APP_DEBUG=0
APP_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_STRING

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_BOT_USERNAME=your_bot_username_without_at

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key

# Database (SQLite for simplicity on free tier)
DATABASE_URL="sqlite:///%kernel.project_dir%/var/data.db"

# Webhook domain (your Oracle Cloud public IP or domain)
WEBHOOK_DOMAIN=your-domain.com
